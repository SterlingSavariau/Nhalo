{
  "name": "nhalo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start:api": "node apps/api/dist/server.js",
    "start": "node apps/api/dist/server.js",
    "build:api": "tsup apps/api/src/server.ts --format esm --target node20 --out-dir apps/api/dist --tsconfig tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run build:api && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "ops:check": "tsx scripts/ops-check.ts",
    "ops:summary": "tsx scripts/ops-summary.ts",
    "ops:seed:verify": "tsx scripts/ops-seed-verify.ts",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.5.0",
    "fastify": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "prisma": "^6.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
