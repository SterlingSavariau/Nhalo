{
  "name": "nhalo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "start:api": "node apps/api/dist/server.js",
    "start": "node apps/api/dist/server.js",
    "build:api": "tsup apps/api/src/server.ts --format esm --target node20 --out-dir apps/api/dist --tsconfig tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build": "npm run build:api && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "ops:check": "tsx scripts/ops-check.ts",
    "ops:summary": "tsx scripts/ops-summary.ts",
    "ops:seed:verify": "tsx scripts/ops-seed-verify.ts",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fastify/cors": "^10.0.1",
    "country-state-city-js": "^2.5.0",
    "google-auth-library": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "fastify": "^5.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
