generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id             String          @id
  provider       String
  sourceUrl      String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float
  longitude      Float
  propertyType   String
  price          Int
  sqft           Int
  bedrooms       Int
  bathrooms      Float
  lotSqft        Int?
  rawPayload     Json?
  createdAt      DateTime
  updatedAt      DateTime
  scoreSnapshots ScoreSnapshot[]
}

model SearchRequest {
  id                    String          @id @default(cuid())
  locationType          String
  locationValue         String
  resolvedCity          String?
  resolvedState         String?
  resolvedPostalCode    String?
  radiusMiles           Float
  budget                Json?
  filters               Json
  weights               Json
  totalCandidatesScanned Int
  totalMatched          Int
  returnedCount         Int
  durationMs            Int
  warnings              Json?
  suggestions           Json?
  createdAt             DateTime        @default(now())
  scoreSnapshots        ScoreSnapshot[]
}

model ScoreSnapshot {
  id              String        @id @default(cuid())
  searchRequestId String
  propertyId      String
  formulaVersion  String
  explanation     String
  priceScore      Int
  sizeScore       Int
  safetyScore     Int
  nhaloScore      Int
  safetyConfidence String
  scoreInputs     Json
  createdAt       DateTime      @default(now())
  property        Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  searchRequest   SearchRequest  @relation(fields: [searchRequestId], references: [id], onDelete: Cascade)

  @@index([searchRequestId])
  @@index([propertyId])
}
