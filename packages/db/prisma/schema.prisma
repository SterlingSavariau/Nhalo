generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id             String          @id
  provider       String
  sourceUrl      String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float
  longitude      Float
  propertyType   String
  price          Int
  sqft           Int
  bedrooms       Int
  bathrooms      Float
  lotSqft        Int?
  rawPayload     Json?
  createdAt      DateTime
  updatedAt      DateTime
  scoreSnapshots ScoreSnapshot[]
}

model SearchRequest {
  id                    String          @id @default(cuid())
  sessionId             String?
  partnerId             String?
  searchDefinitionId    String?
  rerunSourceType       String?
  rerunSourceId         String?
  demoScenarioId        String?
  locationType          String
  locationValue         String
  resolvedCity          String?
  resolvedState         String?
  resolvedPostalCode    String?
  resolvedFormattedAddress String?
  originLatitude        Float?
  originLongitude       Float?
  originPrecision       String?
  geocodeProvider       String?
  geocodeDataSource     String?         @default("none")
  geocodeFetchedAt      DateTime?
  rawGeocodeInputs      Json?
  normalizedGeocodeInputs Json?
  radiusMiles           Float
  budget                Json?
  filters               Json
  weights               Json
  totalCandidatesScanned Int
  totalMatched          Int
  returnedCount         Int
  durationMs            Int
  warnings              Json?
  suggestions           Json?
  createdAt             DateTime        @default(now())
  scoreSnapshots        ScoreSnapshot[]
  dataQualityEvents     DataQualityEvent[]
  feedback              Feedback[]
  validationEvents      ValidationEvent[]
  shortlistItems        ShortlistItem[]  @relation("ShortlistItemSourceHistory")

  @@index([sessionId, createdAt])
  @@index([partnerId, createdAt])
}

model DataQualityEvent {
  id             String   @id @default(cuid())
  ruleId         String
  sourceDomain   String
  severity       String
  category       String
  message        String
  targetType     String
  targetId       String
  partnerId      String?
  sessionId      String?
  provider       String?
  status         String   @default("open")
  contextJson    Json?
  searchRequestId String?
  triggeredAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  searchRequest  SearchRequest? @relation(fields: [searchRequestId], references: [id], onDelete: SetNull)

  @@index([severity, createdAt])
  @@index([sourceDomain, createdAt])
  @@index([provider, createdAt])
  @@index([partnerId, createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([searchRequestId, createdAt])
}

model SearchSnapshot {
  id             String   @id @default(cuid())
  formulaVersion String?
  sessionId      String?
  searchDefinitionId String?
  historyRecordId String?
  demoScenarioId String?
  requestPayload Json
  responsePayload Json
  createdAt      DateTime @default(now())
  sharedLinks    SharedSnapshotLink[]
  feedback       Feedback[]
  validationEvents ValidationEvent[]
  shortlists     Shortlist[]
  shortlistItems ShortlistItem[] @relation("ShortlistItemSourceSnapshot")

  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([historyRecordId, createdAt])
}

model SearchDefinition {
  id           String   @id @default(cuid())
  sessionId    String?
  label        String
  requestPayload Json
  pinned       Boolean  @default(false)
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  feedback     Feedback[]
  validationEvents ValidationEvent[]
  shortlistItems ShortlistItem[] @relation("ShortlistItemSourceDefinition")

  @@index([sessionId, updatedAt])
}

model SharedSnapshotLink {
  id         String   @id @default(cuid())
  shareId    String   @unique
  snapshotId String
  sessionId  String?
  expiresAt  DateTime?
  revokedAt  DateTime?
  openCount  Int      @default(0)
  createdAt  DateTime @default(now())
  snapshot   SearchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, createdAt])
  @@index([shareId, expiresAt, revokedAt])
}

model Feedback {
  id                 String   @id @default(cuid())
  sessionId          String?
  snapshotId         String?
  historyRecordId    String?
  searchDefinitionId String?
  category           String
  value              String
  comment            String?
  createdAt          DateTime @default(now())
  snapshot           SearchSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  searchRequest      SearchRequest? @relation(fields: [historyRecordId], references: [id], onDelete: SetNull)
  searchDefinition   SearchDefinition? @relation(fields: [searchDefinitionId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([snapshotId, createdAt])
  @@index([historyRecordId, createdAt])
}

model ValidationEvent {
  id                 String   @id @default(cuid())
  eventName          String
  sessionId          String?
  snapshotId         String?
  historyRecordId    String?
  searchDefinitionId String?
  demoScenarioId     String?
  payload            Json?
  createdAt          DateTime @default(now())
  snapshot           SearchSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  searchRequest      SearchRequest? @relation(fields: [historyRecordId], references: [id], onDelete: SetNull)
  searchDefinition   SearchDefinition? @relation(fields: [searchDefinitionId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([demoScenarioId, createdAt])
}

model Shortlist {
  id             String   @id @default(cuid())
  sessionId      String?
  title          String
  description    String?
  sourceSnapshotId String?
  pinned         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sourceSnapshot SearchSnapshot? @relation(fields: [sourceSnapshotId], references: [id], onDelete: SetNull)
  items          ShortlistItem[]
  offerReadiness OfferReadiness[]
  negotiations   NegotiationRecord[]
  sharedLinks    SharedShortlistLink[]

  @@index([sessionId, updatedAt])
  @@index([sourceSnapshotId, createdAt])
}

model ShortlistItem {
  id                     String   @id @default(cuid())
  shortlistId            String
  canonicalPropertyId    String
  sourceSnapshotId       String?
  sourceHistoryId        String?
  sourceSearchDefinitionId String?
  capturedHomePayload    Json
  reviewState            String   @default("undecided")
  addedAt                DateTime @default(now())
  updatedAt              DateTime @updatedAt
  shortlist              Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  sourceSnapshot         SearchSnapshot? @relation("ShortlistItemSourceSnapshot", fields: [sourceSnapshotId], references: [id], onDelete: SetNull)
  sourceHistory          SearchRequest? @relation("ShortlistItemSourceHistory", fields: [sourceHistoryId], references: [id], onDelete: SetNull)
  sourceSearchDefinition SearchDefinition? @relation("ShortlistItemSourceDefinition", fields: [sourceSearchDefinitionId], references: [id], onDelete: SetNull)
  notes                  ResultNote[]
  offerReadiness         OfferReadiness?
  reviewerDecisions      ReviewerDecision[]
  comments               SharedComment[]

  @@index([shortlistId, addedAt])
  @@index([canonicalPropertyId, addedAt])
  @@unique([shortlistId, canonicalPropertyId])
}

model FinancialReadiness {
  id                         String   @id @default(cuid())
  sessionId                  String?
  partnerId                  String?
  annualHouseholdIncome      Int?
  monthlyDebtPayments        Int?
  availableCashSavings       Int?
  creditScoreRange           String?
  desiredHomePrice           Int?
  purchaseLocation           String?
  downPaymentPreferencePercent Float?
  loanType                   String?
  preApprovalStatus          String?
  preApprovalExpiresAt       DateTime?
  proofOfFundsStatus         String?
  maxAffordableHomePrice     Int?
  estimatedMonthlyPayment    Int?
  estimatedDownPayment       Int?
  estimatedClosingCosts      Int?
  totalCashRequiredToClose   Int?
  debtToIncomeRatio          Float?
  housingRatio               Float?
  affordabilityClassification String
  readinessState             String
  blockersJson               Json
  recommendation             String
  risk                       String
  alternative                String
  nextAction                 String
  nextStepsJson              Json
  assumptionsJson            Json
  lastEvaluatedAt            DateTime
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([sessionId, updatedAt])
  @@index([partnerId, updatedAt])
}

model OfferReadiness {
  id                     String   @id @default(cuid())
  propertyId             String
  shortlistId            String
  shortlistItemId        String   @unique
  status                 String
  readinessScore         Int
  recommendedOfferPrice  Int
  confidence             String
  financingReadiness     String
  propertyFitConfidence  String
  riskToleranceAlignment String
  riskLevel              String
  userConfirmed          Boolean  @default(false)
  dataCompletenessScore  Int
  blockingIssuesJson     Json
  nextStepsJson          Json
  lastEvaluatedAt        DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  shortlist              Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  shortlistItem          ShortlistItem @relation(fields: [shortlistItemId], references: [id], onDelete: Cascade)
  negotiation            NegotiationRecord?

  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@unique([shortlistId, propertyId])
}

model NegotiationRecord {
  id                  String   @id @default(cuid())
  propertyId          String
  shortlistId         String?
  offerReadinessId    String?  @unique
  status              String
  initialOfferPrice   Int
  currentOfferPrice   Int
  sellerCounterPrice  Int?
  buyerWalkAwayPrice  Int?
  roundNumber         Int      @default(1)
  guidanceHeadline    String
  guidanceRiskLevel   String
  guidanceFlagsJson   Json
  guidanceNextStepsJson Json
  lastActionAt        DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  shortlist           Shortlist? @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  offerReadiness      OfferReadiness? @relation(fields: [offerReadinessId], references: [id], onDelete: SetNull)
  events              NegotiationEvent[]

  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@unique([shortlistId, propertyId])
}

model NegotiationEvent {
  id                  String   @id @default(cuid())
  negotiationRecordId String
  type                String
  label               String
  details             String?
  createdAt           DateTime @default(now())
  negotiationRecord   NegotiationRecord @relation(fields: [negotiationRecordId], references: [id], onDelete: Cascade)

  @@index([negotiationRecordId, createdAt])
}

model SharedShortlistLink {
  id         String   @id @default(cuid())
  shareId    String   @unique
  shortlistId String
  sessionId  String?
  shareMode  String
  expiresAt  DateTime?
  revokedAt  DateTime?
  openCount  Int      @default(0)
  createdAt  DateTime @default(now())
  shortlist  Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  comments   SharedComment[]
  reviewerDecisions ReviewerDecision[]

  @@index([shortlistId, createdAt])
  @@index([shareId, expiresAt, revokedAt])
}

model SharedComment {
  id          String   @id @default(cuid())
  shareId     String
  entityType  String
  entityId    String
  authorLabel String?
  body        String
  shortlistItemId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  share       SharedShortlistLink @relation(fields: [shareId], references: [shareId], onDelete: Cascade)
  shortlistItem ShortlistItem? @relation(fields: [shortlistItemId], references: [id], onDelete: SetNull)

  @@index([shareId, updatedAt])
  @@index([entityType, entityId, updatedAt])
}

model ReviewerDecision {
  id             String   @id @default(cuid())
  shortlistItemId String
  shareId        String
  decision       String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shortlistItem  ShortlistItem @relation(fields: [shortlistItemId], references: [id], onDelete: Cascade)
  share          SharedShortlistLink @relation(fields: [shareId], references: [shareId], onDelete: Cascade)

  @@index([shareId, updatedAt])
  @@index([shortlistItemId, updatedAt])
  @@unique([shareId, shortlistItemId])
}

model PilotPartner {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  planTier        String   @default("free_demo")
  status          String
  contactLabel    String?
  notes           String?
  featureOverrides Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pilotLinks      PilotLink[]
  opsActions      OpsAction[]

  @@index([status, updatedAt])
}

model PilotLink {
  id              String   @id @default(cuid())
  partnerId       String
  token           String   @unique
  allowedFeatures Json
  expiresAt       DateTime?
  revokedAt       DateTime?
  openCount       Int      @default(0)
  createdAt       DateTime @default(now())
  partner         PilotPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([token, expiresAt, revokedAt])
}

model OpsAction {
  id          String   @id @default(cuid())
  actionType  String
  targetType  String
  targetId    String
  partnerId   String?
  result      String
  details     Json?
  performedAt DateTime @default(now())
  partner     PilotPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([partnerId, performedAt])
  @@index([targetType, targetId, performedAt])
}

model ResultNote {
  id          String   @id @default(cuid())
  sessionId   String?
  entityType  String
  entityId    String
  body        String
  shortlistItemId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shortlistItem ShortlistItem? @relation(fields: [shortlistItemId], references: [id], onDelete: SetNull)

  @@index([sessionId, updatedAt])
  @@index([entityType, entityId, updatedAt])
}

model ScoreSnapshot {
  id                    String        @id @default(cuid())
  searchRequestId       String
  propertyId            String
  formulaVersion        String
  explanation           String
  priceScore            Int
  sizeScore             Int
  safetyScore           Int
  nhaloScore            Int
  safetyConfidence      String
  overallConfidence     String
  pricePerSqft          Float
  medianPricePerSqft    Float
  crimeIndex            Float?
  schoolRating          Float?
  neighborhoodStability Float?
  dataCompleteness      Float
  safetyDataSource      String        @default("none")
  crimeProvider         String?
  schoolProvider        String?
  crimeFetchedAt        DateTime?
  schoolFetchedAt       DateTime?
  rawSafetyInputs       Json?
  normalizedSafetyInputs Json?
  listingDataSource     String        @default("none")
  listingProvider       String?
  sourceListingId       String?
  listingFetchedAt      DateTime?
  rawListingInputs      Json?
  normalizedListingInputs Json?
  distanceMiles         Float?
  insideRequestedRadius Boolean       @default(true)
  scoreInputs           Json
  createdAt             DateTime      @default(now())
  property              Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  searchRequest         SearchRequest  @relation(fields: [searchRequestId], references: [id], onDelete: Cascade)

  @@index([searchRequestId])
  @@index([propertyId])
}

model MarketSnapshot {
  id                 String   @id @default(cuid())
  location           String
  radiusMiles        Float
  medianPricePerSqft Float
  sampleSize         Int
  createdAt          DateTime @default(now())

  @@index([location, radiusMiles, createdAt])
}

model SafetySignalCache {
  id                 String   @id @default(cuid())
  locationKey        String
  lat                Float
  lng                Float
  crimeProvider      String?
  schoolProvider     String?
  crimeRaw           Json?
  crimeNormalized    Float?
  schoolRaw          Json?
  schoolNormalized   Float?
  stabilityRaw       Json?
  stabilityNormalized Float?
  fetchedAt          DateTime
  expiresAt          DateTime
  sourceType         String

  @@index([locationKey, fetchedAt])
}

model ListingCache {
  id                 String   @id @default(cuid())
  locationKey        String
  locationType       String
  locationValue      String
  radiusMiles        Float
  provider           String
  rawPayload         Json?
  normalizedListings Json
  fetchedAt          DateTime
  expiresAt          DateTime
  sourceType         String
  rejectionSummary   Json

  @@index([locationKey, fetchedAt])
}

model GeocodeCache {
  id                 String   @id @default(cuid())
  queryType          String
  queryValue         String
  provider           String
  formattedAddress   String?
  latitude           Float
  longitude          Float
  precision          String
  rawPayload         Json?
  normalizedPayload  Json?
  fetchedAt          DateTime
  expiresAt          DateTime
  sourceType         String
  city               String?
  state              String?
  zip                String?
  country            String?

  @@index([queryType, queryValue, fetchedAt])
}
