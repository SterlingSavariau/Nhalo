generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id             String          @id
  provider       String
  sourceUrl      String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float
  longitude      Float
  propertyType   String
  price          Int
  sqft           Int
  bedrooms       Int
  bathrooms      Float
  lotSqft        Int?
  rawPayload     Json?
  createdAt      DateTime
  updatedAt      DateTime
  scoreSnapshots ScoreSnapshot[]
}

model SearchRequest {
  id                       String             @id @default(cuid())
  sessionId                String?
  partnerId                String?
  searchDefinitionId       String?
  rerunSourceType          String?
  rerunSourceId            String?
  demoScenarioId           String?
  locationType             String
  locationValue            String
  resolvedCity             String?
  resolvedState            String?
  resolvedPostalCode       String?
  resolvedFormattedAddress String?
  originLatitude           Float?
  originLongitude          Float?
  originPrecision          String?
  geocodeProvider          String?
  geocodeDataSource        String?            @default("none")
  geocodeFetchedAt         DateTime?
  rawGeocodeInputs         Json?
  normalizedGeocodeInputs  Json?
  radiusMiles              Float
  budget                   Json?
  filters                  Json
  weights                  Json
  totalCandidatesScanned   Int
  totalMatched             Int
  returnedCount            Int
  durationMs               Int
  warnings                 Json?
  suggestions              Json?
  createdAt                DateTime           @default(now())
  scoreSnapshots           ScoreSnapshot[]
  dataQualityEvents        DataQualityEvent[]
  feedback                 Feedback[]
  validationEvents         ValidationEvent[]
  shortlistItems           ShortlistItem[]    @relation("ShortlistItemSourceHistory")

  @@index([sessionId, createdAt])
  @@index([partnerId, createdAt])
}

model DataQualityEvent {
  id              String         @id @default(cuid())
  ruleId          String
  sourceDomain    String
  severity        String
  category        String
  message         String
  targetType      String
  targetId        String
  partnerId       String?
  sessionId       String?
  provider        String?
  status          String         @default("open")
  contextJson     Json?
  searchRequestId String?
  triggeredAt     DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  searchRequest   SearchRequest? @relation(fields: [searchRequestId], references: [id], onDelete: SetNull)

  @@index([severity, createdAt])
  @@index([sourceDomain, createdAt])
  @@index([provider, createdAt])
  @@index([partnerId, createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([searchRequestId, createdAt])
}

model SearchSnapshot {
  id                 String               @id @default(cuid())
  formulaVersion     String?
  sessionId          String?
  searchDefinitionId String?
  historyRecordId    String?
  demoScenarioId     String?
  requestPayload     Json
  responsePayload    Json
  createdAt          DateTime             @default(now())
  sharedLinks        SharedSnapshotLink[]
  feedback           Feedback[]
  validationEvents   ValidationEvent[]
  shortlists         Shortlist[]
  shortlistItems     ShortlistItem[]      @relation("ShortlistItemSourceSnapshot")

  @@index([createdAt])
  @@index([sessionId, createdAt])
  @@index([historyRecordId, createdAt])
}

model SearchDefinition {
  id               String            @id @default(cuid())
  sessionId        String?
  label            String
  requestPayload   Json
  pinned           Boolean           @default(false)
  lastRunAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  feedback         Feedback[]
  validationEvents ValidationEvent[]
  shortlistItems   ShortlistItem[]   @relation("ShortlistItemSourceDefinition")

  @@index([sessionId, updatedAt])
}

model SharedSnapshotLink {
  id         String         @id @default(cuid())
  shareId    String         @unique
  snapshotId String
  sessionId  String?
  expiresAt  DateTime?
  revokedAt  DateTime?
  openCount  Int            @default(0)
  createdAt  DateTime       @default(now())
  snapshot   SearchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, createdAt])
  @@index([shareId, expiresAt, revokedAt])
}

model Feedback {
  id                 String            @id @default(cuid())
  sessionId          String?
  snapshotId         String?
  historyRecordId    String?
  searchDefinitionId String?
  category           String
  value              String
  comment            String?
  createdAt          DateTime          @default(now())
  snapshot           SearchSnapshot?   @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  searchRequest      SearchRequest?    @relation(fields: [historyRecordId], references: [id], onDelete: SetNull)
  searchDefinition   SearchDefinition? @relation(fields: [searchDefinitionId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([snapshotId, createdAt])
  @@index([historyRecordId, createdAt])
}

model ValidationEvent {
  id                 String            @id @default(cuid())
  eventName          String
  sessionId          String?
  snapshotId         String?
  historyRecordId    String?
  searchDefinitionId String?
  demoScenarioId     String?
  payload            Json?
  createdAt          DateTime          @default(now())
  snapshot           SearchSnapshot?   @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  searchRequest      SearchRequest?    @relation(fields: [historyRecordId], references: [id], onDelete: SetNull)
  searchDefinition   SearchDefinition? @relation(fields: [searchDefinitionId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([demoScenarioId, createdAt])
}

model Shortlist {
  id                String                      @id @default(cuid())
  sessionId         String?
  title             String
  description       String?
  sourceSnapshotId  String?
  pinned            Boolean                     @default(false)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  sourceSnapshot    SearchSnapshot?             @relation(fields: [sourceSnapshotId], references: [id], onDelete: SetNull)
  items             ShortlistItem[]
  offerPreparations OfferPreparation[]
  offerSubmissions  OfferSubmission[]
  underContracts    UnderContractCoordination[]
  closingReadiness  ClosingReadiness[]
  offerReadiness    OfferReadiness[]
  negotiations      NegotiationRecord[]
  sharedLinks       SharedShortlistLink[]

  @@index([sessionId, updatedAt])
  @@index([sourceSnapshotId, createdAt])
}

model ShortlistItem {
  id                        String             @id @default(cuid())
  shortlistId               String
  canonicalPropertyId       String
  sourceSnapshotId          String?
  sourceHistoryId           String?
  sourceSearchDefinitionId  String?
  capturedHomePayload       Json
  reviewState               String             @default("undecided")
  choiceStatus              String             @default("candidate")
  selectionRank             Int?
  decisionConfidence        String?
  decisionRationale         String?
  decisionRisksJson         Json               @default("[]")
  lastDecisionReviewedAt    DateTime?
  selectedAt                DateTime?
  statusChangedAt           DateTime           @default(now())
  replacedByShortlistItemId String?
  replacedByShortlistItem   ShortlistItem?     @relation("ShortlistItemReplacement", fields: [replacedByShortlistItemId], references: [id], onDelete: SetNull)
  replacedItems             ShortlistItem[]    @relation("ShortlistItemReplacement")
  droppedReason             String?
  addedAt                   DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  shortlist                 Shortlist          @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  sourceSnapshot            SearchSnapshot?    @relation("ShortlistItemSourceSnapshot", fields: [sourceSnapshotId], references: [id], onDelete: SetNull)
  sourceHistory             SearchRequest?     @relation("ShortlistItemSourceHistory", fields: [sourceHistoryId], references: [id], onDelete: SetNull)
  sourceSearchDefinition    SearchDefinition?  @relation("ShortlistItemSourceDefinition", fields: [sourceSearchDefinitionId], references: [id], onDelete: SetNull)
  notes                     ResultNote[]
  offerReadiness            OfferReadiness?
  reviewerDecisions         ReviewerDecision[]
  comments                  SharedComment[]

  @@unique([shortlistId, canonicalPropertyId])
  @@index([shortlistId, addedAt])
  @@index([shortlistId, choiceStatus])
  @@index([shortlistId, selectionRank])
  @@index([canonicalPropertyId, addedAt])
  @@index([replacedByShortlistItemId])
}

model FinancialReadiness {
  id                           String                      @id @default(cuid())
  sessionId                    String?
  partnerId                    String?
  annualHouseholdIncome        Int?
  monthlyDebtPayments          Int?
  availableCashSavings         Int?
  creditScoreRange             String?
  desiredHomePrice             Int?
  purchaseLocation             String?
  downPaymentPreferencePercent Float?
  loanType                     String?
  preApprovalStatus            String?
  preApprovalExpiresAt         DateTime?
  proofOfFundsStatus           String?
  maxAffordableHomePrice       Int?
  estimatedMonthlyPayment      Int?
  estimatedDownPayment         Int?
  estimatedClosingCosts        Int?
  totalCashRequiredToClose     Int?
  debtToIncomeRatio            Float?
  housingRatio                 Float?
  affordabilityClassification  String
  readinessState               String
  blockersJson                 Json
  recommendation               String
  risk                         String
  alternative                  String
  nextAction                   String
  nextStepsJson                Json
  assumptionsJson              Json
  lastEvaluatedAt              DateTime
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt
  offerPreparations            OfferPreparation[]
  offerSubmissions             OfferSubmission[]
  underContracts               UnderContractCoordination[]
  closingReadiness             ClosingReadiness[]

  @@index([sessionId, updatedAt])
  @@index([partnerId, updatedAt])
}

model OfferPreparation {
  id                               String                      @id @default(cuid())
  sessionId                        String?
  partnerId                        String?
  propertyId                       String
  propertyAddressLabel             String
  shortlistId                      String?
  offerReadinessId                 String?
  financialReadinessId             String
  offerPrice                       Int?
  earnestMoneyAmount               Int?
  downPaymentType                  String?
  downPaymentAmount                Int?
  downPaymentPercent               Float?
  financingContingency             String?
  inspectionContingency            String?
  appraisalContingency             String?
  closingTimelineDays              Int?
  possessionTiming                 String?
  possessionDaysAfterClosing       Int?
  sellerConcessionsRequestedAmount Int?
  notes                            String?
  buyerRationale                   String?
  offerSummaryJson                 Json
  offerState                       String
  offerRiskLevel                   String
  offerCompletenessState           String
  readinessToSubmit                Boolean                     @default(false)
  cashRequiredAtOffer              Int?
  missingItemsJson                 Json
  blockersJson                     Json
  recommendation                   String
  risk                             String
  alternative                      String
  nextAction                       String
  nextStepsJson                    Json
  financialAlignmentJson           Json
  assumptionsJson                  Json
  strategyDefaultsProvenanceJson   Json?
  lastEvaluatedAt                  DateTime
  createdAt                        DateTime                    @default(now())
  updatedAt                        DateTime                    @updatedAt
  shortlist                        Shortlist?                  @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  financialReadiness               FinancialReadiness          @relation(fields: [financialReadinessId], references: [id], onDelete: Cascade)
  offerReadiness                   OfferReadiness?             @relation(fields: [offerReadinessId], references: [id], onDelete: SetNull)
  offerSubmissions                 OfferSubmission[]
  underContracts                   UnderContractCoordination[]
  closingReadiness                 ClosingReadiness[]

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@index([financialReadinessId, updatedAt])
  @@index([sessionId, updatedAt])
}

model OfferSubmission {
  id                                String                     @id @default(cuid())
  sessionId                         String?
  partnerId                         String?
  propertyId                        String
  propertyAddressLabel              String
  shortlistId                       String?
  financialReadinessId              String?
  offerPreparationId                String
  submissionMethod                  String?
  submittedAt                       DateTime?
  offerExpirationAt                 DateTime?
  sellerResponseState               String
  sellerRespondedAt                 DateTime?
  buyerCounterDecision              String?
  withdrawnAt                       DateTime?
  withdrawalReason                  String?
  notes                             String?
  internalActivityNote              String?
  originalOfferSnapshotJson         Json
  submissionSummaryJson             Json
  submissionState                   String
  urgencyLevel                      String
  counterofferPrice                 Int?
  counterofferClosingTimelineDays   Int?
  counterofferFinancingContingency  String?
  counterofferInspectionContingency String?
  counterofferAppraisalContingency  String?
  counterofferExpirationAt          DateTime?
  counterofferSummaryJson           Json
  missingItemsJson                  Json
  blockersJson                      Json
  recommendation                    String
  risk                              String
  alternative                       String
  nextAction                        String
  nextStepsJson                     Json
  requiresBuyerResponse             Boolean                    @default(false)
  isExpired                         Boolean                    @default(false)
  activityLogJson                   Json
  lastActionAt                      DateTime?
  lastEvaluatedAt                   DateTime
  createdAt                         DateTime                   @default(now())
  updatedAt                         DateTime                   @updatedAt
  shortlist                         Shortlist?                 @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  financialReadiness                FinancialReadiness?        @relation(fields: [financialReadinessId], references: [id], onDelete: SetNull)
  offerPreparation                  OfferPreparation           @relation(fields: [offerPreparationId], references: [id], onDelete: Cascade)
  underContract                     UnderContractCoordination?
  closingReadiness                  ClosingReadiness[]

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@index([offerPreparationId, updatedAt])
  @@index([financialReadinessId, updatedAt])
  @@index([sessionId, updatedAt])
}

model UnderContractCoordination {
  id                         String              @id @default(cuid())
  sessionId                  String?
  partnerId                  String?
  propertyId                 String
  propertyAddressLabel       String
  shortlistId                String?
  financialReadinessId       String?
  offerPreparationId         String?
  offerSubmissionId          String              @unique
  acceptedAt                 DateTime
  targetClosingDate          DateTime
  inspectionDeadline         DateTime?
  appraisalDeadline          DateTime?
  financingDeadline          DateTime?
  contingencyDeadline        DateTime?
  closingPreparationDeadline DateTime?
  notes                      String?
  internalActivityNote       String?
  coordinationSummaryJson    Json
  overallCoordinationState   String
  overallRiskLevel           String
  urgencyLevel               String
  readyForClosing            Boolean             @default(false)
  requiresImmediateAttention Boolean             @default(false)
  taskRecordsJson            Json
  milestoneRecordsJson       Json
  deadlineRecordsJson        Json
  missingItemsJson           Json
  blockersJson               Json
  recommendation             String
  risk                       String
  alternative                String
  nextAction                 String
  nextStepsJson              Json
  activityLogJson            Json
  lastActionAt               DateTime?
  lastEvaluatedAt            DateTime
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  shortlist                  Shortlist?          @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  financialReadiness         FinancialReadiness? @relation(fields: [financialReadinessId], references: [id], onDelete: SetNull)
  offerPreparation           OfferPreparation?   @relation(fields: [offerPreparationId], references: [id], onDelete: SetNull)
  offerSubmission            OfferSubmission     @relation(fields: [offerSubmissionId], references: [id], onDelete: Cascade)
  closingReadiness           ClosingReadiness?

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@index([offerSubmissionId, updatedAt])
  @@index([financialReadinessId, updatedAt])
  @@index([offerPreparationId, updatedAt])
  @@index([sessionId, updatedAt])
}

model ClosingReadiness {
  id                             String                    @id @default(cuid())
  sessionId                      String?
  partnerId                      String?
  propertyId                     String
  propertyAddressLabel           String
  shortlistId                    String?
  financialReadinessId           String?
  offerPreparationId             String?
  offerSubmissionId              String?
  underContractCoordinationId    String                    @unique
  targetClosingDate              DateTime
  closingAppointmentAt           DateTime?
  closingAppointmentLocation     String?
  closingAppointmentNotes        String?
  finalReviewDeadline            DateTime?
  finalFundsConfirmationDeadline DateTime?
  finalFundsAmountConfirmed      Int?
  closedAt                       DateTime?
  notes                          String?
  internalActivityNote           String?
  closingSummaryJson             Json
  overallClosingReadinessState   String
  overallRiskLevel               String
  urgencyLevel                   String
  readyToClose                   Boolean                   @default(false)
  closed                         Boolean                   @default(false)
  checklistItemsJson             Json
  milestoneRecordsJson           Json
  missingItemsJson               Json
  blockersJson                   Json
  recommendation                 String
  risk                           String
  alternative                    String
  nextAction                     String
  nextStepsJson                  Json
  activityLogJson                Json
  requiresImmediateAttention     Boolean                   @default(false)
  lastActionAt                   DateTime?
  lastEvaluatedAt                DateTime
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  shortlist                      Shortlist?                @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  financialReadiness             FinancialReadiness?       @relation(fields: [financialReadinessId], references: [id], onDelete: SetNull)
  offerPreparation               OfferPreparation?         @relation(fields: [offerPreparationId], references: [id], onDelete: SetNull)
  offerSubmission                OfferSubmission?          @relation(fields: [offerSubmissionId], references: [id], onDelete: SetNull)
  underContractCoordination      UnderContractCoordination @relation(fields: [underContractCoordinationId], references: [id], onDelete: Cascade)

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
  @@index([underContractCoordinationId, updatedAt])
  @@index([offerSubmissionId, updatedAt])
  @@index([financialReadinessId, updatedAt])
  @@index([offerPreparationId, updatedAt])
  @@index([sessionId, updatedAt])
}

model WorkflowNotification {
  id                     String                             @id @default(cuid())
  workflowId             String?
  sessionId              String?
  propertyId             String?
  propertyAddressLabel   String?
  shortlistId            String?
  moduleName             String
  alertCategory          String
  severity               String
  status                 String
  triggeringRuleLabel    String
  relatedSubjectType     String
  relatedSubjectId       String
  title                  String
  message                String
  actionLabel            String?
  actionTargetJson       Json?
  dueAt                  DateTime?
  readAt                 DateTime?
  dismissedAt            DateTime?
  resolvedAt             DateTime?
  explanationSubjectType String?
  explanationSubjectId   String?
  createdAt              DateTime                           @default(now())
  updatedAt              DateTime                           @updatedAt
  historyEvents          WorkflowNotificationHistoryEvent[]

  @@index([sessionId, updatedAt])
  @@index([propertyId, updatedAt])
  @@index([shortlistId, updatedAt])
  @@index([status, updatedAt])
  @@index([severity, updatedAt])
  @@index([moduleName, updatedAt])
  @@index([relatedSubjectType, relatedSubjectId, updatedAt])
  @@index([triggeringRuleLabel, dueAt, updatedAt])
}

model WorkflowNotificationHistoryEvent {
  id             String               @id @default(cuid())
  notificationId String
  eventType      String
  previousValue  String?
  nextValue      String?
  createdAt      DateTime             @default(now())
  notification   WorkflowNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, createdAt])
}

model UnifiedActivityLog {
  id                    String   @id @default(cuid())
  workflowId            String?
  sessionId             String?
  propertyId            String?
  propertyAddressLabel  String?
  shortlistId           String?
  moduleName            String
  eventCategory         String
  subjectType           String
  subjectId             String
  title                 String
  summary               String
  oldValueSnapshotJson  Json?
  newValueSnapshotJson  Json?
  triggerType           String
  triggerLabel          String
  actorType             String
  actorId               String?
  relatedNotificationId String?
  relatedExplanationId  String?
  createdAt             DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([propertyId, createdAt])
  @@index([shortlistId, createdAt])
  @@index([moduleName, createdAt])
  @@index([eventCategory, createdAt])
  @@index([subjectType, subjectId, createdAt])
}

model OfferReadiness {
  id                     String             @id @default(cuid())
  propertyId             String
  shortlistId            String
  shortlistItemId        String             @unique
  status                 String
  readinessScore         Int
  recommendedOfferPrice  Int
  confidence             String
  financingReadiness     String
  propertyFitConfidence  String
  riskToleranceAlignment String
  riskLevel              String
  userConfirmed          Boolean            @default(false)
  dataCompletenessScore  Int
  blockingIssuesJson     Json
  nextStepsJson          Json
  lastEvaluatedAt        DateTime
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  shortlist              Shortlist          @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  shortlistItem          ShortlistItem      @relation(fields: [shortlistItemId], references: [id], onDelete: Cascade)
  offerPreparations      OfferPreparation[]
  negotiation            NegotiationRecord?

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
}

model NegotiationRecord {
  id                    String             @id @default(cuid())
  propertyId            String
  shortlistId           String?
  offerReadinessId      String?            @unique
  status                String
  initialOfferPrice     Int
  currentOfferPrice     Int
  sellerCounterPrice    Int?
  buyerWalkAwayPrice    Int?
  roundNumber           Int                @default(1)
  guidanceHeadline      String
  guidanceRiskLevel     String
  guidanceFlagsJson     Json
  guidanceNextStepsJson Json
  lastActionAt          DateTime
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  shortlist             Shortlist?         @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  offerReadiness        OfferReadiness?    @relation(fields: [offerReadinessId], references: [id], onDelete: SetNull)
  events                NegotiationEvent[]

  @@unique([shortlistId, propertyId])
  @@index([shortlistId, updatedAt])
  @@index([propertyId, updatedAt])
}

model NegotiationEvent {
  id                  String            @id @default(cuid())
  negotiationRecordId String
  type                String
  label               String
  details             String?
  createdAt           DateTime          @default(now())
  negotiationRecord   NegotiationRecord @relation(fields: [negotiationRecordId], references: [id], onDelete: Cascade)

  @@index([negotiationRecordId, createdAt])
}

model SharedShortlistLink {
  id                String             @id @default(cuid())
  shareId           String             @unique
  shortlistId       String
  sessionId         String?
  shareMode         String
  expiresAt         DateTime?
  revokedAt         DateTime?
  openCount         Int                @default(0)
  createdAt         DateTime           @default(now())
  shortlist         Shortlist          @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  comments          SharedComment[]
  reviewerDecisions ReviewerDecision[]

  @@index([shortlistId, createdAt])
  @@index([shareId, expiresAt, revokedAt])
}

model SharedComment {
  id              String              @id @default(cuid())
  shareId         String
  entityType      String
  entityId        String
  authorLabel     String?
  body            String
  shortlistItemId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  share           SharedShortlistLink @relation(fields: [shareId], references: [shareId], onDelete: Cascade)
  shortlistItem   ShortlistItem?      @relation(fields: [shortlistItemId], references: [id], onDelete: SetNull)

  @@index([shareId, updatedAt])
  @@index([entityType, entityId, updatedAt])
}

model ReviewerDecision {
  id              String              @id @default(cuid())
  shortlistItemId String
  shareId         String
  decision        String
  note            String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  shortlistItem   ShortlistItem       @relation(fields: [shortlistItemId], references: [id], onDelete: Cascade)
  share           SharedShortlistLink @relation(fields: [shareId], references: [shareId], onDelete: Cascade)

  @@unique([shareId, shortlistItemId])
  @@index([shareId, updatedAt])
  @@index([shortlistItemId, updatedAt])
}

model PilotPartner {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  planTier         String      @default("free_demo")
  status           String
  contactLabel     String?
  notes            String?
  featureOverrides Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  pilotLinks       PilotLink[]
  opsActions       OpsAction[]

  @@index([status, updatedAt])
}

model PilotLink {
  id              String       @id @default(cuid())
  partnerId       String
  token           String       @unique
  allowedFeatures Json
  expiresAt       DateTime?
  revokedAt       DateTime?
  openCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  partner         PilotPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([token, expiresAt, revokedAt])
}

model OpsAction {
  id          String        @id @default(cuid())
  actionType  String
  targetType  String
  targetId    String
  partnerId   String?
  result      String
  details     Json?
  performedAt DateTime      @default(now())
  partner     PilotPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([partnerId, performedAt])
  @@index([targetType, targetId, performedAt])
}

model ResultNote {
  id              String         @id @default(cuid())
  sessionId       String?
  entityType      String
  entityId        String
  body            String
  shortlistItemId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  shortlistItem   ShortlistItem? @relation(fields: [shortlistItemId], references: [id], onDelete: SetNull)

  @@index([sessionId, updatedAt])
  @@index([entityType, entityId, updatedAt])
}

model ScoreSnapshot {
  id                      String        @id @default(cuid())
  searchRequestId         String
  propertyId              String
  formulaVersion          String
  explanation             String
  priceScore              Int
  sizeScore               Int
  safetyScore             Int
  nhaloScore              Int
  safetyConfidence        String
  overallConfidence       String
  pricePerSqft            Float
  medianPricePerSqft      Float
  crimeIndex              Float?
  schoolRating            Float?
  neighborhoodStability   Float?
  dataCompleteness        Float
  safetyDataSource        String        @default("none")
  crimeProvider           String?
  schoolProvider          String?
  crimeFetchedAt          DateTime?
  schoolFetchedAt         DateTime?
  rawSafetyInputs         Json?
  normalizedSafetyInputs  Json?
  listingDataSource       String        @default("none")
  listingProvider         String?
  sourceListingId         String?
  listingFetchedAt        DateTime?
  rawListingInputs        Json?
  normalizedListingInputs Json?
  distanceMiles           Float?
  insideRequestedRadius   Boolean       @default(true)
  scoreInputs             Json
  createdAt               DateTime      @default(now())
  property                Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  searchRequest           SearchRequest @relation(fields: [searchRequestId], references: [id], onDelete: Cascade)

  @@index([searchRequestId])
  @@index([propertyId])
}

model MarketSnapshot {
  id                 String   @id @default(cuid())
  location           String
  radiusMiles        Float
  medianPricePerSqft Float
  sampleSize         Int
  createdAt          DateTime @default(now())

  @@index([location, radiusMiles, createdAt])
}

model SafetySignalCache {
  id                  String   @id @default(cuid())
  locationKey         String
  lat                 Float
  lng                 Float
  crimeProvider       String?
  schoolProvider      String?
  crimeRaw            Json?
  crimeNormalized     Float?
  schoolRaw           Json?
  schoolNormalized    Float?
  stabilityRaw        Json?
  stabilityNormalized Float?
  fetchedAt           DateTime
  expiresAt           DateTime
  sourceType          String

  @@index([locationKey, fetchedAt])
}

model ListingCache {
  id                 String   @id @default(cuid())
  locationKey        String
  locationType       String
  locationValue      String
  radiusMiles        Float
  provider           String
  rawPayload         Json?
  normalizedListings Json
  fetchedAt          DateTime
  expiresAt          DateTime
  sourceType         String
  rejectionSummary   Json

  @@index([locationKey, fetchedAt])
}

model GeocodeCache {
  id                String   @id @default(cuid())
  queryType         String
  queryValue        String
  provider          String
  formattedAddress  String?
  latitude          Float
  longitude         Float
  precision         String
  rawPayload        Json?
  normalizedPayload Json?
  fetchedAt         DateTime
  expiresAt         DateTime
  sourceType        String
  city              String?
  state             String?
  zip               String?
  country           String?

  @@index([queryType, queryValue, fetchedAt])
}
